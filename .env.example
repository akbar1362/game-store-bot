# Game Store Bot Environment Variables
# Copy this file to .env and fill in the values

# Bot Token from @BotFather
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Admin Telegram IDs (comma-separated)
ADMIN_IDS=YOUR_TELEGRAM_ID

# Store Settings
STORE_NAME=GameStore Pro
STORE_DESCRIPTION=frooshgah takhasosi bazi-haye Xbox va PlayStation
STORE_LOGO=
STORE_BANNER=
STORE_PHONE=
STORE_CARD_NUMBER=
STORE_CARD_HOLDER=
STORE_CARD_BANK=

# Support
SUPPORT_USERNAME=
CHANNEL_ID=

# Tax Rate (percentage)
TAX_RATE=0

# Wallet
WALLET_TOP_UP_MIN=50000

# Logging
LOG_LEVEL=INFO

# Backup
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
